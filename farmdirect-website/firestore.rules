rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function userRole() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }

    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /farmerProfiles/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
    }

    match /consumerProfiles/{userId} {
      allow read: if isAuth();
      allow create, update: if isOwner(userId);
    }

    match /crops/{cropId} {
      allow read: if true;
      allow create: if isAuth() && userRole() == 'farmer';
      allow update, delete: if isAuth() && resource.data.farmerId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow read: if isAuth() && (resource.data.consumerId == request.auth.uid || resource.data.farmerId == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.farmerId == request.auth.uid || resource.data.consumerId == request.auth.uid);
    }

    match /cart/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /wishlist/{wishlistId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /payments/{paymentId} {
      allow read: if isAuth();
      allow create: if isAuth();
    }

    match /marketPrices/{priceId} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /farmers/{farmerId} {
      allow read: if isAuth();
      allow create: if true;
    }

    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /negotiations/{negotiationId} {
      allow read: if isAuth() && (resource.data.farmerId == request.auth.uid || resource.data.consumerId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.consumerId == request.auth.uid;
      allow update: if isAuth() && (resource.data.farmerId == request.auth.uid || resource.data.consumerId == request.auth.uid);
    }

    match /messages/{messageId} {
      allow read: if isAuth() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth();
    }
  }
}

# Firebase (optional - defaults are in firebase.js)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=

# Stripe Publishable Key (frontend only - NEVER put secret key here)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Stripe Secret Key goes in Firebase Functions config:
# firebase functions:config:set stripe.secret_key="sk_test_..." stripe.webhook_secret="whsec_..."
